// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int     @id @default(autoincrement())
  email      String  @unique
  password   String
  name       String
  department String?
  grade      Int?

  listings Listing[] @relation("SellerListing")   

  purchases Listing[] @relation("BuyerListing")

  buyerChats  ChatRoom[] @relation("BuyerChat")

  sellerChats ChatRoom[] @relation("SellerChat")

  messages Message[] @relation("UserMessages")
}

model BookMaster {
  id            Int      @id @default(autoincrement())

  title         String
  author        String?
  publisher     String?
  isbn          String?  @unique

  originalPrice Int

  courseName    String

  listings      Listing[]
}

enum ListingStatus {
  SELLING
  RESERVED
  SOLD
}


model Listing {
  id          Int      @id @default(autoincrement())

  price       Int
  condition   String?
  imageUrl    String?
  
  status      ListingStatus @default(SELLING)

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  sellerId    Int
  seller User @relation("SellerListing", fields: [sellerId], references: [id])

  bookId      Int
  book         BookMaster @relation(fields: [bookId], references: [id])

  buyerId Int?

  buyer User? @relation("BuyerListing", fields: [buyerId], references: [id])

  chatRooms ChatRoom[]
}

model ChatRoom {
  id        Int      @id @default(autoincrement())

  listingId Int
  listing   Listing @relation(fields: [listingId], references: [id])

  buyerId   Int
  buyer     User @relation("BuyerChat", fields: [buyerId], references: [id])

  sellerId  Int
  seller    User @relation("SellerChat", fields: [sellerId], references: [id])

  createdAt DateTime @default(now())

  messages  Message[]
}

model Message {
  id         Int      @id @default(autoincrement())

  chatRoomId Int
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id])

  senderId   Int
  sender     User @relation("UserMessages", fields: [senderId], references: [id])

  content    String

  createdAt  DateTime @default(now())
}