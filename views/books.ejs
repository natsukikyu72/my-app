<!DOCTYPE html>
<html lang="ja">

<head>

<meta charset="UTF-8">

<title>教科書一覧</title>

<link rel="stylesheet" href="/css/style.css">

</head>

<body>

<h1>

教科書マスタ

</h1>

<% books.forEach(book=>{ %>

<div class="card">

<h2>

<%= book.title %>

</h2>

<p>

授業：
<%= book.courseName %>

</p>

<p>

著者：
<%= book.author ?? "-" %>

</p>

<p>

出版社：
<%= book.publisher ?? "-" %>

</p>

<p>

定価：
<%= book.originalPrice %>円

</p>

</div>

<% }) %>

</body>

</html>