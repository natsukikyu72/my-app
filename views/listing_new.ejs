<!DOCTYPE html>
<html lang="ja">

<head>
<meta charset="UTF-8">
<title>教科書を出品</title>

<link rel="stylesheet" href="/css/style.css">

</head>

<body>

<%- include("partials/header") %>

<div class="container">

<h1>教科書を出品</h1>

<div class="card">

<form
    action="/listing"
    method="post"
    enctype="multipart/form-data">

<label>教科書</label>

<select name="bookId">

<% books.forEach(book=>{ %>

<option value="<%= book.id %>">

<%= book.title %>

（<%= book.courseName %>）

</option>

<% }) %>

</select>

<label>販売価格</label>

<input
type="number"
name="price"
required>

<label>商品の状態</label>

<select name="condition">

<option>新品同様</option>

<option>ほぼ新品</option>

<option>書き込みあり</option>

<option>傷・汚れあり</option>

</select>

<label>画像</label>

<input
type="file"
name="image"
accept="image/*">

<button>

出品する

</button>

</form>

</div>

<br>

<a href="/">← ホームへ戻る</a>

</body>

</html>