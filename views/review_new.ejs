<!DOCTYPE html>
<html lang="ja">

<head>

<meta charset="UTF-8">

<title>評価する</title>

<link rel="stylesheet" href="/css/style.css">

</head>

<body>

<%- include("partials/header") %>

<div class="container">

<h1>

<%= listing.book.title %>

を評価

</h1>

<div class="card">

<form action="/review" method="post">

<input
type="hidden"
name="listingId"
value="<%= listing.id %>">

<label>

評価

</label>

<select name="rating">

<option value="5">★★★★★</option>

<option value="4">★★★★☆</option>

<option value="3">★★★☆☆</option>

<option value="2">★★☆☆☆</option>

<option value="1">★☆☆☆☆</option>

</select>

<label>

コメント

</label>

<textarea
name="comment"
placeholder="コメントを入力"></textarea>

<button>

送信する

</button>

</form>

</div>
</div>

</body>

</html>