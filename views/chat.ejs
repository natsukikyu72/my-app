<!DOCTYPE html>
<html lang="ja">

<head>
<meta charset="UTF-8">
<title>購入相談</title>
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="nav">

<h1>購入相談</h1>

<a href="/listing/<%= chatRoom.listing.id %>">

商品へ戻る

</a>

</div>

<div class="card">

<h2>

<%= chatRoom.listing.book.title %>

</h2>

<p>

授業：
<%= chatRoom.listing.book.courseName %>

</p>

</div>

<h2>

メッセージ

</h2>

<% if(chatRoom.messages.length===0){ %>

<div class="card">

まだメッセージはありません

</div>

<% } %>

<% chatRoom.messages.forEach(message=>{ %>

<div class="message <%= message.senderId===myId?'mine':'' %>">

<strong>

<a href="/user/<%= message.sender.id %>">

<%= message.sender.name %>

</a>

</strong>

<br><br>

<%= message.content %>

<br><br>

<div class="small">

<%= message.createdAt.toLocaleString() %>

</div>

</div>

<% }) %>

<form action="/chat/<%= chatRoom.id %>/message" method="post">

<textarea
name="content"
placeholder="メッセージを入力"
required></textarea>

<button>

送信

</button>

</form>

<br>

<% if(chatRoom.sellerId===myId && chatRoom.listing.status==="SELLING"){ %>

<form action="/chat/<%= chatRoom.id %>/accept" method="post">

<button>

この人と取引する

</button>

</form>

<% } %>

<% if(chatRoom.listing.status==="RESERVED"){ %>

<form action="/listing/<%= chatRoom.listing.id %>/complete" method="post">

<button>

受け渡し完了

</button>

</form>

<% } %>

</body>
</html>