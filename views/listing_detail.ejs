<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title><%= listing.book.title %></title>
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<%- include("partials/header") %>

<div class="container">

<div class="detail-card">

<div class="image-wrapper">
<img src="<%= listing.imageUrl || '/images/no-image.png' %>" class="detail-image">

<span class="status <%= listing.status.toLowerCase() %>">
<%= listing.status==="SELLING" ? "販売中" : listing.status==="RESERVED" ? "取引中" : "売却済み" %>
</span>

</div>

<h1><%= listing.book.title %></h1>

<p>📖 授業<br><%= listing.book.courseName %></p>

<p class="price">
¥<%= listing.price.toLocaleString() %>
</p>

<p>定価：<%= listing.book.originalPrice.toLocaleString() %>円</p>

<p>状態：<%= listing.condition ?? "未設定" %></p>

<p>
出品者：
<a href="/user/<%= listing.seller.id %>">
<%= listing.seller.name %>
</a>
</p>

</div>


<% if(listing.sellerId !== myId && listing.status==="SELLING"){ %>

<form action="/chat/start/<%= listing.id %>" method="post">
<button class="main-button">
購入相談する
</button>
</form>

<% } %>


<% if(listing.status==="RESERVED" && listing.buyerId===myId){ %>

<form action="/chat/start/<%= listing.id %>" method="post">
<button>
取引中チャットを見る
</button>
</form>

<% } %>


<%
const alreadyReviewed = listing.reviews.some(
r => r.reviewerId === myId
);
%>


<% if(
listing.status==="SOLD" &&
!alreadyReviewed &&
(listing.sellerId===myId || listing.buyerId===myId)
){ %>

<a href="/review/new/<%= listing.id %>">
<button>
評価する
</button>
</a>

<% } %>


<% if(listing.sellerId===myId){ %>

<h2>購入相談一覧</h2>

<% if(listing.chatRooms.length===0){ %>

<div class="chat-card">
まだ相談はありません。
</div>

<% }else{ %>

<% listing.chatRooms.forEach(chat=>{ %>

<div class="chat-card">

<p>
購入希望者：
<a href="/user/<%= chat.buyer.id %>">
<%= chat.buyer.name %>
</a>
</p>

<% if(chat.messages.length){ %>

<p>
<%= chat.messages[0].content %>
</p>

<% }else{ %>

<p>
メッセージなし
</p>

<% } %>

<a href="/chat/<%= chat.id %>">
<button>
チャットを見る
</button>
</a>

</div>

<% }) %>

<% } %>

<% } %>

</div>

</body>
</html>