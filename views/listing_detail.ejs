<!DOCTYPE html>
<html lang="ja">

<head>
<meta charset="UTF-8">
<title><%= listing.book.title %></title>
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="nav">
    <h1><%= listing.book.title %></h1>

    <a href="/">← ホーム</a>
</div>

<div class="card">

<p><strong>授業</strong><br>
<%= listing.book.courseName %></p>

<br>

<p><strong>定価</strong><br>
<%= listing.book.originalPrice %>円</p>

<br>

<p><strong>販売価格</strong><br>
<%= listing.price %>円</p>

<br>

<p><strong>状態</strong><br>
<%= listing.condition ?? "未設定" %></p>

<br>

<p>

<strong>出品者</strong><br>

<a href="/user/<%= listing.seller.id %>">
<%= listing.seller.name %>
</a>

</p>

<br>

<% if(listing.imageUrl){ %>

<img src="<%= listing.imageUrl %>">

<% }else{ %>

<p>画像はありません。</p>

<% } %>

<hr>

<% if(listing.status==="SELLING"){ %>

<p class="status-selling">
販売中
</p>

<% } %>

<% if(listing.status==="RESERVED"){ %>

<p class="status-reserved">
取引中
</p>

<% } %>

<% if(listing.status==="SOLD"){ %>

<p class="status-sold">
売却済み
</p>

<% } %>

</div>

<% if (listing.sellerId !== myId && listing.status==="SELLING"){ %>

<form action="/chat/start/<%= listing.id %>" method="post">

<button>
購入相談する
</button>

</form>

<% } %>

<% if(
listing.status==="RESERVED"
&& listing.buyerId===myId
){ %>

<form action="/chat/start/<%= listing.id %>" method="post">

<button>

取引中チャットを見る

</button>

</form>

<% } %>

<%
const alreadyReviewed=
listing.reviews.some(r=>r.reviewerId===myId);
%>

<% if(
listing.status==="SOLD"
&& !alreadyReviewed
&& (listing.sellerId===myId||listing.buyerId===myId)
){ %>

<p>

<a href="/review/new/<%= listing.id %>">

<button>

評価する

</button>

</a>

</p>

<% } %>

<% if(listing.sellerId===myId){ %>

<h2>購入相談一覧</h2>

<% if(listing.chatRooms.length===0){ %>

<div class="card">

まだ相談はありません。

</div>

<% } %>

<% listing.chatRooms.forEach(chat=>{ %>

<div class="card">

<p>

<a href="/user/<%= chat.buyer.id %>">

<%= chat.buyer.name %>

</a>

</p>

<% if(chat.messages.length){ %>

<p>

<%= chat.messages[0].content %>

</p>

<% } %>

<a href="/chat/<%= chat.id %>">

<button>

チャットを見る

</button>

</a>

</div>

<% }) %>

<% } %>

</body>
</html>