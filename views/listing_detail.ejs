<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= listing.book.title %> | 教科書詳細 | 慶應教科書フリマ</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=Noto+Serif+JP:wght@600;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        keio: {
                            blue: '#002F6C',
                            red: '#9E0B0E',
                            gold: '#C5A059',
                            dark: '#0B132B'
                        }
                    },
                    fontFamily: {
                        sans: ['Noto Sans JP', 'sans-serif'],
                        serif: ['Noto Serif JP', 'serif'],
                    }
                }
            }
        }
    </script>
    <style>
        .keio-stripe {
            background: linear-gradient(to right, #002F6C 42%, #9E0B0E 42%, #9E0B0E 58%, #002F6C 58%);
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col justify-between">

    <!-- Top Tricolor Pennant Stripe -->
    <div class="keio-stripe h-1.5 w-full sticky top-0 z-50"></div>

    <!-- Navigation Header -->
    <header class="bg-white border-b border-slate-100 shadow-sm sticky top-1.5 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <a href="/" class="flex items-center gap-2.5 group">
                <div class="w-10 h-10 bg-gradient-to-br from-keio-blue to-keio-red rounded-lg flex items-center justify-center text-white shadow-md transition-transform group-hover:scale-105">
                    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 20L10 14M20 4L14 10" stroke-linecap="round"/>
                        <path d="M10 14L13 11L11 9L8 12L7 15L10 14Z" fill="currentColor" opacity="0.3"/>
                        <path d="M14 10L11 13L13 15L16 12L17 9L14 10Z" fill="currentColor" opacity="0.3"/>
                    </svg>
                </div>
                <div>
                    <h1 class="font-serif font-extrabold text-base sm:text-lg text-keio-blue leading-tight tracking-wider">
                        慶應教科書フリマ
                    </h1>
                    <p class="text-[9px] text-slate-400 font-bold uppercase tracking-widest -mt-0.5">
                        Keio Book Loop
                    </p>
                </div>
            </a>
            <a href="/" class="text-xs font-bold text-slate-500 hover:text-keio-blue flex items-center gap-1 bg-slate-100 px-3 py-2 rounded-lg transition-colors">
                ← 検索ホームに戻る
            </a>
        </div>
    </header>

    <!-- Main Content Grid -->
    <main class="flex-grow max-w-5xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-10">
        
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
            
            <!-- Left Side: Book Cover Image Panel (4 cols) -->
            <div class="md:col-span-5 space-y-6">
                <div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-md">
                    <% if (listing.imageUrl) { %>
                        <div class="w-full rounded-xl overflow-hidden shadow-inner bg-slate-50 aspect-3/4">
                            <img src="<%= listing.imageUrl %>" alt="<%= listing.book.title %>" class="w-full h-full object-cover">
                        </div>
                    <% } else { %>
                        <!-- Simulated Beautiful Leather Book Cover -->
                        <div class="relative w-full aspect-3/4 bg-gradient-to-br from-keio-blue via-slate-800 to-keio-red rounded-xl overflow-hidden flex flex-col justify-between p-6 shadow-2xl text-white">
                            <div class="keio-stripe h-1.5 w-full absolute top-0 left-0"></div>
                            <div class="flex justify-between items-start">
                                <span class="text-[10px] font-bold tracking-widest text-amber-200 bg-white/10 px-2.5 py-1 rounded backdrop-blur-xs uppercase">Keio Textbook</span>
                                <svg class="w-6 h-6 text-amber-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                            </div>
                            <div class="my-auto text-center">
                                <h4 class="font-serif text-lg sm:text-xl font-bold tracking-wider leading-relaxed text-white"><%= listing.book.title %></h4>
                                <span class="text-xs text-slate-200 mt-2 inline-block border-b border-white/20 pb-1 font-medium"><%= listing.book.courseName %></span>
                            </div>
                            <div class="flex justify-between items-center text-[10px] text-slate-300">
                                <span>慶應義塾大学</span>
                                <span class="font-bold">手渡し保証</span>
                            </div>
                        </div>
                    <% } %>
                </div>

                <!-- Status Banner Alert -->
                <% if (listing.status === "RESERVED") { %>
                    <div class="bg-amber-50 border border-amber-200 text-amber-800 p-4 rounded-xl text-center shadow-sm flex items-center justify-center gap-2">
                        <span class="w-2.5 h-2.5 rounded-full bg-amber-500 animate-ping"></span>
                        <span class="font-bold text-sm">現在、購入希望者と取引中です（取置中）</span>
                    </div>
                <% } else if (listing.status === "SOLD") { %>
                    <div class="bg-slate-100 border border-slate-200 text-slate-600 p-4 rounded-xl text-center shadow-sm">
                        <span class="font-bold text-sm">この商品は売却完了いたしました。</span>
                    </div>
                <% } %>
            </div>

            <!-- Right Side: Textbook Details & Actions (7 cols) -->
            <div class="md:col-span-7 space-y-6">
                
                <!-- Main details card -->
                <div class="bg-white rounded-2xl border border-slate-100 shadow-md p-6 sm:p-8 relative overflow-hidden">
                    <div class="keio-stripe h-1 w-full absolute top-0 left-0"></div>
                    
                    <div class="flex items-center gap-2 text-xs font-bold text-slate-400 mb-2">
                        <svg class="w-4 h-4 text-keio-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                        </svg>
                        講義科目：<%= listing.book.courseName %>
                    </div>

                    <h2 class="font-serif font-extrabold text-xl sm:text-2xl text-slate-800 leading-tight mb-4">
                        <%= listing.book.title %>
                    </h2>

                    <!-- Spec tags -->
                    <div class="flex flex-wrap gap-2 mb-6">
                        <span class="px-3 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded-lg border border-slate-200">
                            状態：<%= listing.condition ?? "未設定" %>
                        </span>
                        <% if (listing.book.originalPrice > listing.price) { 
                            const saving = Math.round((1 - (listing.price / listing.book.originalPrice)) * 100);
                        %>
                            <span class="px-3 py-1 bg-red-50 text-keio-red text-xs font-bold rounded-lg border border-red-100">
                                定価の <%= saving %>% 引
                            </span>
                        <% } %>
                    </div>

                    <!-- Pricing Plate -->
                    <div class="bg-slate-50 rounded-xl p-5 mb-8 flex justify-between items-center border border-slate-100">
                        <div>
                            <span class="text-xs font-bold text-slate-400 block mb-1">出品希望価格</span>
                            <div class="text-keio-blue font-black text-3xl flex items-baseline">
                                <span class="text-sm font-bold mr-0.5">¥</span><%= listing.price.toLocaleString() %>
                            </div>
                        </div>
                        <div class="text-right border-l border-slate-200 pl-6">
                            <span class="text-xs font-semibold text-slate-400 block mb-1">本学書店定価</span>
                            <div class="text-slate-500 font-bold text-sm line-through">
                                ¥<%= listing.book.originalPrice.toLocaleString() %>
                            </div>
                        </div>
                    </div>

                    <!-- Seller Card -->
                    <div class="border-t border-slate-100 pt-6 mb-8">
                        <h3 class="text-xs font-extrabold text-slate-400 uppercase tracking-widest mb-3">出品者情報</h3>
                        <div class="flex items-center justify-between p-3.5 bg-slate-50 rounded-xl hover:bg-slate-100/70 transition-colors">
                            <div class="flex items-center gap-2.5">
                                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-keio-blue to-keio-red text-white font-bold text-sm flex items-center justify-center">
                                    <%= listing.seller.name.substring(0, 1) %>
                                </div>
                                <div>
                                    <h4 class="font-bold text-sm text-slate-800"><%= listing.seller.name %></h4>
                                    <p class="text-[11px] text-slate-500 font-medium"><%= listing.seller.department || "塾生" %></p>
                                </div>
                            </div>
                            <a href="/user/<%= listing.seller.id %>" class="text-xs font-bold text-keio-blue hover:underline">
                                プロフィールを見る →
                            </a>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="space-y-3">
                        <% if (listing.sellerId !== myId && listing.status === "SELLING") { %>
                            <form action="/chat/start/<%= listing.id %>" method="post" class="w-full">
                                <button type="submit" class="w-full bg-keio-blue hover:bg-slate-900 text-white font-bold py-4 px-4 rounded-xl shadow-lg shadow-blue-900/15 hover:shadow-xl hover:shadow-blue-900/25 active:scale-[0.98] transition-all text-sm tracking-widest text-center">
                                    この教科書の購入相談を開始する
                                </button>
                            </form>
                        <% } %>

                        <% if (listing.status === "RESERVED" && listing.buyerId === myId) { %>
                            <form action="/chat/start/<%= listing.id %>" method="post" class="w-full">
                                <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-4 px-4 rounded-xl shadow-lg active:scale-[0.98] transition-all text-sm tracking-widest text-center">
                                    取引チャットへ進む
                                </button>
                            </form>
                        <% } %>

                        <% 
                        const alreadyReviewed = listing.reviews.some(review => review.reviewerId === myId);
                        %>

                        <% if (listing.status === "SOLD" && (listing.sellerId === myId || listing.buyerId === myId) && !alreadyReviewed) { %>
                            <a href="/review/new/<%= listing.id %>" class="block w-full text-center bg-keio-red hover:bg-red-800 text-white font-bold py-4 px-4 rounded-xl shadow-md transition-all text-sm tracking-widest">
                                取引相手を評価する
                            </a>
                        <% } %>
                    </div>

                </div>

                <!-- Buyer consultation list for the seller (only if seller view) -->
                <% if (listing.sellerId === myId) { %>
                    <div class="bg-white rounded-2xl border border-slate-100 shadow-md p-6 sm:p-8">
                        <h3 class="font-serif text-base font-bold text-keio-blue mb-4 pb-2 border-b border-slate-100 flex items-center gap-2">
                            <span class="w-1.5 h-4 bg-keio-red rounded-full"></span>
                            購入相談・オファー一覧
                        </h3>

                        <% if (listing.chatRooms.length === 0) { %>
                            <div class="text-center py-8 text-slate-400">
                                <p class="text-xs font-semibold mb-1">購入相談はまだありません。</p>
                                <p class="text-[10px] text-slate-300">相談が届くとここにチャットルームが作られます。</p>
                            </div>
                        <% } else { %>
                            <div class="divide-y divide-slate-100">
                                <% listing.chatRooms.forEach(chat => { %>
                                    <div class="py-4 first:pt-0 last:pb-0 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                                        <div>
                                            <div class="flex items-center gap-2 mb-1">
                                                <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                                                <span class="text-xs font-bold text-slate-700">購入希望者：</span>
                                                <a href="/user/<%= chat.buyer.id %>" class="text-xs font-bold text-keio-blue hover:underline">
                                                    <%= chat.buyer.name %>
                                                </a>
                                            </div>
                                            
                                            <% if (chat.messages.length > 0) { %>
                                                <p class="text-xs text-slate-500 bg-slate-50 p-2 rounded-lg italic line-clamp-1">
                                                    「<%= chat.messages[0].content %>」
                                                </p>
                                            <% } else { %>
                                                <p class="text-[10px] text-slate-400 italic">
                                                    まだメッセージはありません。
                                                </p>
                                            <% } %>
                                        </div>

                                        <a href="/chat/<%= chat.id %>" class="shrink-0 text-center bg-slate-100 hover:bg-keio-blue hover:text-white text-slate-700 font-bold px-4 py-2 rounded-lg text-xs transition-colors">
                                            チャットを見る
                                        </a>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                <% } %>

            </div>

        </div>

    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-200 py-6 text-center text-slate-400 text-[10px] tracking-wider">
        &copy; 2026 慶應教科書フリマ (Keio Book Loop) . All Rights Reserved.<br>
        <span class="text-[9px] mt-1 inline-block text-slate-300">「実学の精神」に基づき、塾生同士の知の循環をサポートします。</span>
    </footer>

</body>
</html>