<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>教科書フリマ</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include("partials/header") %>

<div class="container">

<div class="search-box">
<h2>🔍 教科書検索</h2>
<form action="/" method="get">
<input type="text" name="keyword" value="<%= keyword %>" placeholder="教科書名・授業名で検索">
<button>検索</button>
</form>
</div>

<% if(listings.length===0){ %>

<p>該当する商品はありません。</p>

<% }else{ %>

<div class="listing-grid">

<% listings.forEach(listing=>{ %>

<a href="/listing/<%= listing.id %>" class="listing-link">

<div class="listing-card">

<div class="image-wrapper">
<img src="<%= listing.imageUrl || '/images/no-image.png' %>" class="book-image">

<span class="status <%= listing.status.toLowerCase() %>">
<%= listing.status==="SELLING" ? "販売中" : listing.status==="RESERVED" ? "取引中" : "売却済み" %>
</span>

</div>

<h3><%= listing.book.title %></h3>

<p>📖 <%= listing.book.courseName %></p>

<p class="price">
¥<%= listing.price.toLocaleString() %>
</p>

<p class="original">
定価 ¥<%= listing.book.originalPrice.toLocaleString() %>
</p>

<p>状態：<%= listing.condition ?? "未設定" %></p>

<p class="seller">
👤 <%= listing.seller.name %>
</p>

</div>

</a>

<% }) %>

</div>

<% } %>

</div>

</body>
</html>