<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ホーム | 慶應教科書フリマ (Keio Book Loop)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=Noto+Serif+JP:wght@600;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        keio: {
                            blue: '#002F6C',
                            red: '#9E0B0E',
                            gold: '#C5A059',
                            dark: '#0B132B'
                        }
                    },
                    fontFamily: {
                        sans: ['Noto Sans JP', 'sans-serif'],
                        serif: ['Noto Serif JP', 'serif'],
                    }
                }
            }
        }
    </script>
    <style>
        .keio-stripe {
            background: linear-gradient(to right, #002F6C 42%, #9E0B0E 42%, #9E0B0E 58%, #002F6C 58%);
        }
        .text-shadow-sm {
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.4);
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col justify-between">

    <!-- Top Tricolor Pennant Stripe -->
    <div class="keio-stripe h-1.5 w-full sticky top-0 z-50"></div>

    <!-- Navigation Header -->
    <header class="bg-white border-b border-slate-100 shadow-sm sticky top-1.5 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            
            <!-- Logo -->
            <a href="/" class="flex items-center gap-2.5 group">
                <div class="w-10 h-10 bg-gradient-to-br from-keio-blue to-keio-red rounded-lg flex items-center justify-center text-white shadow-md transition-transform group-hover:scale-105">
                    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 20L10 14M20 4L14 10" stroke-linecap="round"/>
                        <path d="M10 14L13 11L11 9L8 12L7 15L10 14Z" fill="currentColor" opacity="0.3"/>
                        <path d="M14 10L11 13L13 15L16 12L17 9L14 10Z" fill="currentColor" opacity="0.3"/>
                    </svg>
                </div>
                <div>
                    <h1 class="font-serif font-extrabold text-base sm:text-lg text-keio-blue leading-tight tracking-wider">
                        慶應教科書フリマ
                    </h1>
                    <p class="text-[9px] text-slate-400 font-bold uppercase tracking-widest -mt-0.5">
                        Keio Book Loop
                    </p>
                </div>
            </a>

            <!-- Search Status & MyPage Actions -->
            <div class="flex items-center gap-3">
                <div class="hidden sm:flex flex-col items-end text-xs mr-2">
                    <span class="font-bold text-slate-700">塾生: <%= myName %> 様</span>
                    <span class="text-[10px] text-emerald-600 font-semibold flex items-center gap-1">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-ping"></span>
                        keio.jp ログイン中
                    </span>
                </div>

                <a href="/user/<%= myId %>" class="inline-flex items-center gap-1 px-3 py-2 text-xs font-bold text-slate-700 bg-slate-100 hover:bg-keio-blue hover:text-white rounded-lg transition-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    マイページ
                </a>

                <form action="/logout" method="post" class="inline">
                    <button type="submit" class="p-2 text-slate-400 hover:text-keio-red hover:bg-red-50 rounded-lg transition-colors" title="ログアウト">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                    </button>
                </form>
            </div>

        </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow">
        
        <!-- Hero Section with Search bar -->
        <section class="bg-keio-blue text-white py-12 px-4 shadow-inner relative overflow-hidden">
            <!-- Background pattern decoration -->
            <div class="absolute inset-0 bg-[radial-gradient(#ffffff08_1px,transparent_1px)] [background-size:16px_16px] pointer-events-none"></div>
            
            <div class="max-w-4xl mx-auto text-center relative z-10">
                <p class="font-serif text-amber-300 text-xs sm:text-sm font-semibold tracking-widest mb-2 uppercase">
                    “ペンは剣よりも強し” — 塾生による知の継承を
                </p>
                <h2 class="font-serif text-2xl sm:text-4xl font-extrabold tracking-wider mb-6 text-shadow-sm">
                    慶應生のための教科書マーケット
                </h2>
                
                <!-- Search Console -->
                <form action="/" method="get" class="max-w-xl mx-auto">
                    <div class="bg-white p-1.5 rounded-xl shadow-lg flex items-center gap-1 border border-slate-200">
                        <div class="flex-grow flex items-center pl-3">
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                            <input 
                                type="text" 
                                name="keyword" 
                                value="<%= keyword %>"
                                placeholder="教科書名、授業名、著者、学部などから検索..." 
                                class="w-full bg-transparent border-none text-slate-800 placeholder-slate-400 focus:outline-none pl-2 text-sm font-medium"
                            >
                        </div>
                        <button type="submit" class="bg-keio-blue hover:bg-slate-900 text-white text-xs sm:text-sm font-bold px-5 py-2.5 rounded-lg transition-colors shadow-md">
                            検索
                        </button>
                    </div>
                </form>

                <% if (keyword) { %>
                    <p class="text-xs text-slate-300 mt-3 font-semibold">
                        「<span class="text-white font-bold"><%= keyword %></span>」の検索結果
                        <a href="/" class="ml-2 underline text-amber-300 hover:text-amber-200 text-[10px]">クリア</a>
                    </p>
                <% } %>
            </div>
        </section>

        <!-- Secondary Banner / Sell Invitation -->
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
            <div class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-100 rounded-2xl p-5 sm:p-6 flex flex-col sm:flex-row items-center justify-between gap-4 shadow-sm">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 bg-amber-500/10 rounded-full flex items-center justify-center text-amber-700">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-800 text-sm sm:text-base">使わなくなった講義ノート・教科書はありますか？</h3>
                        <p class="text-xs text-slate-500">学期末に溜まった教科書を簡単に出品。同じ塾生に直接手渡しで引き継げます。</p>
                    </div>
                </div>
                <a href="/listing/new" class="w-full sm:w-auto text-center bg-keio-red hover:bg-red-800 text-white font-bold px-6 py-3 rounded-xl shadow-md shadow-red-900/10 hover:shadow-lg hover:shadow-red-900/20 active:scale-[0.98] transition-all text-sm tracking-wide shrink-0">
                    教科書を出品する
                </a>
            </div>
        </div>

        <!-- Textbook Listings Grid -->
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
            <div class="flex items-center justify-between mb-6 border-b border-slate-200 pb-3">
                <h3 class="font-serif text-lg sm:text-xl font-bold text-keio-blue flex items-center gap-2">
                    <span class="w-1.5 h-6 bg-keio-red rounded-full"></span>
                    流通中の教科書一覧
                </h3>
                <span class="text-xs text-slate-500 font-bold">
                    全 <%= listings.length %> 件の出品
                </span>
            </div>

            <% if (listings.length === 0) { %>
                <div class="text-center py-16 bg-white rounded-2xl border border-slate-100 shadow-sm">
                    <svg class="w-16 h-16 text-slate-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                    <p class="text-sm font-medium text-slate-500 mb-1">該当する教科書がありません。</p>
                    <p class="text-xs text-slate-400">キーワードを変えるか、一覧をリセットしてください。</p>
                    <a href="/" class="mt-4 inline-block bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold px-4 py-2 rounded-lg text-xs transition-colors">一覧に戻る</a>
                </div>
            <% } else { %>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                    <% listings.forEach(listing => { %>
                        <div class="bg-white rounded-xl shadow-xs border border-slate-100 overflow-hidden hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 flex flex-col justify-between">
                            
                            <!-- Card Header (Book cover or Image) -->
                            <div class="relative">
                                <% if (listing.imageUrl) { %>
                                    <div class="w-full h-48 bg-slate-100 overflow-hidden relative">
                                        <img src="<%= listing.imageUrl %>" alt="<%= listing.book.title %>" class="w-full h-full object-cover">
                                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                                    </div>
                                <% } else { %>
                                    <!-- Beautiful Academic Synthetic Book Cover -->
                                    <div class="relative w-full h-48 bg-gradient-to-br from-keio-blue via-slate-800 to-keio-red overflow-hidden flex flex-col justify-between p-4 text-white">
                                        <div class="keio-stripe h-1 w-full absolute top-0 left-0"></div>
                                        <div class="flex justify-between items-start">
                                            <span class="text-[9px] font-bold tracking-wider text-amber-200/90 bg-white/10 px-2 py-0.5 rounded backdrop-blur-xs uppercase">Keio Flea</span>
                                            <svg class="w-4 h-4 text-amber-300/80" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                        </div>
                                        <div class="my-auto text-center px-1">
                                            <h4 class="font-serif text-sm font-bold tracking-wide line-clamp-2 text-white leading-snug"><%= listing.book.title %></h4>
                                            <span class="text-[9px] text-slate-200/80 mt-1 inline-block border-b border-white/20 pb-0.5"><%= listing.book.courseName %></span>
                                        </div>
                                        <div class="flex justify-between items-center text-[8px] text-slate-300/80">
                                            <span>慶應義塾大学</span>
                                            <span>知の循環</span>
                                        </div>
                                    </div>
                                <% } %>

                                <!-- Status Badge Overlay -->
                                <div class="absolute top-3 right-3 z-10">
                                    <% if (listing.status === "SELLING") { %>
                                        <span class="bg-emerald-500 text-white text-[10px] font-bold px-2.5 py-1 rounded-full shadow-md">
                                            販売中
                                        </span>
                                    <% } else if (listing.status === "RESERVED") { %>
                                        <span class="bg-amber-500 text-white text-[10px] font-bold px-2.5 py-1 rounded-full shadow-md animate-pulse">
                                            取引中
                                        </span>
                                    <% } else if (listing.status === "SOLD") { %>
                                        <span class="bg-slate-500 text-white text-[10px] font-bold px-2.5 py-1 rounded-full shadow-md">
                                            売却済
                                        </span>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Card Body -->
                            <div class="p-4 flex-grow flex flex-col justify-between">
                                <div>
                                    <!-- Course tag -->
                                    <div class="flex items-center gap-1 text-slate-400 mb-1.5">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                                        </svg>
                                        <span class="text-xs font-semibold text-slate-500 truncate max-w-[180px]" title="<%= listing.book.courseName %>">
                                            <%= listing.book.courseName %>
                                        </span>
                                    </div>

                                    <!-- Book Title -->
                                    <h4 class="font-bold text-slate-800 text-sm sm:text-base line-clamp-1 mb-2 hover:text-keio-blue" title="<%= listing.book.title %>">
                                        <%= listing.book.title %>
                                    </h4>

                                    <!-- Tags Row: Condition & Saving Rate -->
                                    <div class="flex flex-wrap gap-1.5 mb-4">
                                        <!-- Condition tag -->
                                        <% if (listing.condition === "新品同様") { %>
                                            <span class="bg-emerald-50 text-emerald-700 border border-emerald-100 text-[9px] font-bold px-1.5 py-0.5 rounded">
                                                美品
                                            </span>
                                        <% } else if (listing.condition === "ほぼ新品") { %>
                                            <span class="bg-teal-50 text-teal-700 border border-teal-100 text-[9px] font-bold px-1.5 py-0.5 rounded">
                                                ほぼ新品
                                            </span>
                                        <% } else if (listing.condition === "書き込みあり") { %>
                                            <span class="bg-amber-50 text-amber-700 border border-amber-100 text-[9px] font-bold px-1.5 py-0.5 rounded">
                                                書込有
                                            </span>
                                        <% } else { %>
                                            <span class="bg-slate-50 text-slate-700 border border-slate-100 text-[9px] font-bold px-1.5 py-0.5 rounded">
                                                使用感有
                                            </span>
                                        <% } %>

                                        <!-- Calculated Savings Tag -->
                                        <% if (listing.book.originalPrice > listing.price) { 
                                            const saving = Math.round((1 - (listing.price / listing.book.originalPrice)) * 100);
                                        %>
                                            <span class="bg-red-50 text-keio-red border border-red-100 text-[9px] font-bold px-1.5 py-0.5 rounded">
                                                <%= saving %>% OFF
                                            </span>
                                        <% } %>
                                    </div>
                                </div>

                                <!-- Bottom Pricing & Seller Info -->
                                <div class="border-t border-slate-50 pt-3">
                                    <div class="flex items-baseline justify-between mb-2">
                                        <div class="text-keio-blue font-extrabold text-lg sm:text-xl">
                                            <span class="text-xs">¥</span><%= listing.price.toLocaleString() %>
                                        </div>
                                        <div class="text-[10px] text-slate-400 line-through">
                                            定価: ¥<%= listing.book.originalPrice.toLocaleString() %>
                                        </div>
                                    </div>

                                    <div class="flex items-center justify-between text-[11px] text-slate-500 bg-slate-50 p-2 rounded-lg">
                                        <div class="flex items-center gap-1.5">
                                            <div class="w-5 h-5 rounded-full bg-keio-blue/10 flex items-center justify-center text-keio-blue font-bold text-[9px]">
                                                <%= listing.seller.name.substring(0, 1) %>
                                            </div>
                                            <span class="font-semibold text-slate-700 truncate max-w-[80px]">
                                                <%= listing.seller.name %>
                                            </span>
                                        </div>
                                        <span class="text-[9px] text-slate-400 font-medium">
                                            <%= listing.seller.department || "塾生" %>
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Card Footer Action -->
                            <div class="p-4 pt-0">
                                <a href="/listing/<%= listing.id %>" class="block text-center w-full bg-slate-100 hover:bg-keio-blue hover:text-white text-slate-700 text-xs font-bold py-2.5 rounded-lg transition-all">
                                    詳細を見る
                                </a>
                            </div>

                        </div>
                    <% }) %>
                </div>

            <% } %>
        </section>

    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-200 mt-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 text-center text-xs text-slate-500">
            <div class="flex justify-center gap-6 mb-4 font-bold text-slate-600">
                <a href="/" class="hover:text-keio-blue transition-colors">ホーム</a>
                <a href="/listing/new" class="hover:text-keio-blue transition-colors">出品する</a>
                <a href="/books" class="hover:text-keio-blue transition-colors">マスター書籍一覧</a>
            </div>
            <p class="leading-relaxed">
                &copy; 2026 慶應教科書フリマ (Keio Book Loop) . Created for Keio University Students.<br>
                <span class="text-[10px] text-slate-400 mt-1 inline-block">「ペンマーク」と「三色旗」を胸に、塾生同士でスマートで安心な手渡し本取引を。</span>
            </p>
        </div>
    </footer>

</body>
</html>