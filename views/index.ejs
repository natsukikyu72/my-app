<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>教科書フリマ</title>
</head>
<body>

<h2>こんにちは、<%= myName %> さん</h2>

<form action="/logout" method="post">
    <button type="submit">ログアウト</button>
</form>

<hr>

<h2>教科書検索</h2>

<form action="/" method="get">
    <input
        type="text"
        name="keyword"
        value="<%= keyword %>"
        placeholder="教科書名・授業名を入力">

    <button type="submit">検索</button>
</form>

<p>
    <a href="/listing/new">
        <button>教科書を出品する</button>
    </a>
</p>

<hr>

<h2>教科書一覧</h2>

<% if (listings.length === 0) { %>

    <p>該当する教科書がありません。</p>

<% } else { %>

    <% listings.forEach(listing => { %>

        <div style="border:1px solid black; padding:10px; margin-bottom:10px;">

            <h3><%= listing.book.title %></h3>

            <p>授業：<%= listing.book.courseName %></p>

            <p>出品価格：<%= listing.price %>円</p>

            <p>定価：<%= listing.book.originalPrice %>円</p>

            <p>状態：<%= listing.condition ?? "未設定" %></p>

            <p>出品者：<%= listing.seller.name %></p>
            
            <a href="/listing/<%= listing.id %>">
              <button>詳細を見る</button>
            </a>
        </div>

    <% }) %>

<% } %>

</body>
</html>