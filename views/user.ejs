<!DOCTYPE html>
<html lang="ja">

<head>
<meta charset="UTF-8">
<title><%= user.name %></title>
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<%- include("partials/header") %>

<div class="container">


<h1>

<%= user.name %>

</h1>

<a href="/">ホーム</a>

</div>

<div class="card">

<%

let avg=0;

if(user.reviewsReceived.length){

avg=(user.reviewsReceived.reduce((a,r)=>a+r.rating,0)
/user.reviewsReceived.length).toFixed(1);

}

%>

<h2>

評価

</h2>

<p>

<a href="/user/<%= user.id %>/reviews">

⭐ <%= avg %>

（<%= user.reviewsReceived.length %>件）

</a>

</p>

</div>

<h2>

出品一覧

</h2>

<% if(user.listings.length===0){ %>

<div class="card">

出品はありません

</div>

<% } %>

<% user.listings.forEach(listing=>{ %>

<div class="card">

<h3>

<a href="/listing/<%= listing.id %>">

<%= listing.book.title %>

</a>

</h3>

<p>

価格：
<%= listing.price %>円

</p>

<p>

状態：
<%= listing.status %>

</p>

</div>

<% }) %>

</body>
</html>