<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>新規登録</title>
</head>
<body>
    <h1>新規登録</h1>
<form action="/signup" method="post">
  <input type="email" name="email" placeholder="メール" required><br>
  <input type="password" name="password" placeholder="パスワード" required><br>
  <input type="text" name="name" placeholder="名前" required><br>
  <input type="text" name="department" placeholder="学部・学科"><br>
  <input type="number" name="grade" placeholder="学年"><br>
  <button type="submit">登録</button>
</form>
<a href="/login">ログインはこちら</a>
</body>
</html>